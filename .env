# Mx-Tools AI - Configuración Completa
PROJECT_NAME=Mx-Tools AI
VERSION=3.0.0
API_PREFIX=/api/v1
SECRET_KEY=tu_clave_super_segura_cambia_esto
DEBUG=False
LOG_LEVEL=INFO

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# Modelos IA
NLP_MODEL=bert-base-uncased
CODE_MODEL=microsoft/codebert-base
CODET5_MODEL=Salesforce/codet5-base

# Paths
VULN_DB_PATH=./data/vuln_db.json
CWE_DATASET_PATH=./data/cwe_data
FINETUNED_MODEL_PATH=./models/cwe_finetuned

# Ethical Limits
ALLOW_ETHICAL_ATTACKS_ONLY=True
TARGET_SCOPE_FILE=./data/authorized_targets.txt
MAX_CODE_LENGTH=10000

# Multi-language Support
SUPPORTED_LANGUAGES=python,java,go,rust,javascript
